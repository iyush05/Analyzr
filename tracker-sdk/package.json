{
  "name": "@iyush05/analyzr",
  "version": "1.0.2",
  "description": "Lightweight JavaScript tracking SDK for user analytics",
  "main": "dist/tracker.cjs.js",
  "module": "dist/tracker.esm.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/tracker.esm.js",
      "require": "./dist/tracker.cjs.js",
      "default": "./dist/tracker.cjs.js"
    }
  },
  "types": "index.d.ts",
  "files": [
    "dist",
    "index.d.ts"
  ],
  "scripts": {
    "build": "node esbuild.config.js",
    "dev": "node esbuild.config.js --watch"
  },
  "devDependencies": {
    "esbuild": "^0.21.0"
  },
  "keywords": [
    "analytics",
    "tracking",
    "heatmap",
    "user-analytics"
  ],
  "license": "MIT"
}
